# GemCopy by Amipi - Environment variables
# Copy to .env.local and fill in your values.

# --- REQUIRED ---

# Google Gemini API key (get one at https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# --- OPTIONAL (Phase D) ---

# Supabase (auth + database). Create a free project at supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (payments). Create keys at dashboard.stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_PRO=

# Upstash Redis (durable rate limiting). Create at upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry (error tracking). Free tier at sentry.io
SENTRY_DSN=
